# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# FunASR 语音识别服务配置
# 本地部署的 FunASR 服务地址
FUNASR_SERVICE_URL=http://localhost:8000

# 智谱 AI GLM-4 配置 (智能判题)
# Get API Key from: https://open.bigmodel.cn/usercenter/apikeys
# API Key 格式: id.secret
NEXT_PUBLIC_ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI API Configuration (可选 - 备用 AI 判题)
# Get API Key from: https://platform.openai.com/api-keys
# NEXT_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
